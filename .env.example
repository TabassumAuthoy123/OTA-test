APP_NAME="FaithTrip OTA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# Docker: use mysql (service name), port 3306. Host: 127.0.0.1, port 3307.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=otaplatform
DB_USERNAME=otauser
DB_PASSWORD=otapass

# ── Mail / SMTP ───────────────────────────────────────────────────────────────
# Stored in DB (email_configures table) — .env fallback only
MAIL_MAILER=smtp
MAIL_HOST=mail.faithtrip.net
MAIL_PORT=587
MAIL_USERNAME=info@faithtrip.net
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@faithtrip.net
MAIL_FROM_NAME="FaithTrip"

# ── Cache / Session / Queue ───────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── SSL Commerz Payment ───────────────────────────────────────────────────────
SSLC_STORE_ID=
SSLC_STORE_PASSWORD=
SSLC_STORE_CURRENCY=BDT
SSLC_ALLOW_LOCALHOST=true
SSLC_ROUTE_SUCCESS=ssl.payment.success
SSLC_ROUTE_FAILURE=ssl.payment.failure
SSLC_ROUTE_CANCEL=ssl.payment.cancel
SSLC_ROUTE_IPN=ssl.payment.ipn

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── AWS (optional) ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Pusher (optional) ────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
